--- a/kernel/uvm/conftest.sh	2026-06-26 01:32:02.300785201 +0300
+++ b/kernel/uvm/conftest.sh	2026-06-26 01:31:03.634311207 +0300
@@ -196,7 +196,7 @@
 }
 
 build_cflags() {
-    BASE_CFLAGS="-std=gnu17 -O2 -Wno-implicit-function-declaration -Wno-incompatible-pointer-types -D__KERNEL__ \
+    BASE_CFLAGS="-std=gnu17 -fms-extensions -O2 -Wno-implicit-function-declaration -Wno-incompatible-pointer-types -D__KERNEL__ \
 -DKBUILD_BASENAME=\"#conftest$$\" -DKBUILD_MODNAME=\"#conftest$$\" \
 -nostdinc -isystem $ISYSTEM"
 
--- a/kernel/dkms.conf	2026-06-26 01:32:02.146740966 +0300
+++ b/kernel/dkms.conf	2026-06-26 02:19:20.376257207 +0300
@@ -4,10 +4,20 @@
   num_cpu_cores=1
 fi
 
+# Detect a clang/LLVM-built target kernel (CachyOS and other -clang/-lto kernels).
+# Such kernels embed clang-only CFLAGS (e.g. -mstack-alignment=8), so building the
+# module with gcc fails with "unrecognized command-line option". When the running
+# kernel was built with clang we must build with the matching LLVM toolchain.
+_nv_llvm=""
+_nv_kcfg="/usr/lib/modules/${kernelver}/build/.config"
+if [ -f "$_nv_kcfg" ] && grep -q '^CONFIG_CC_IS_CLANG=y' "$_nv_kcfg"; then
+  _nv_llvm="CC=clang HOST_CC=clang LD=ld.lld LLVM=1"
+fi
+
 PACKAGE_NAME="nvidia"
 PACKAGE_VERSION="340.108"
 BUILT_MODULE_NAME[0]="$PACKAGE_NAME"
 DEST_MODULE_LOCATION[0]="/kernel/drivers/video"
-MAKE[0]="make -j$num_cpu_cores module KERNEL_UNAME=${kernelver}"
+MAKE[0]="make -j$num_cpu_cores module SYSSRC=/usr/lib/modules/${kernelver}/build $_nv_llvm"
 CLEAN="make clean"
 AUTOINSTALL="yes"
--- a/kernel/uvm/dkms.conf.fragment	2019-12-12 01:04:24.000000000 +0300
+++ b/kernel/uvm/dkms.conf.fragment	2026-06-26 02:19:20.376338157 +0300
@@ -1,5 +1,5 @@
 BUILT_MODULE_NAME[1]="${PACKAGE_NAME}-uvm"
 BUILT_MODULE_LOCATION[1]="uvm/"
 DEST_MODULE_LOCATION[1]="/kernel/drivers/video"
-MAKE[0]+="; make -C uvm module KERNEL_UNAME=${kernelver} KBUILD_EXTMOD=${dkms_tree}/${PACKAGE_NAME}/${PACKAGE_VERSION}/build/uvm"
+MAKE[0]+="; make -C uvm module SYSSRC=/usr/lib/modules/${kernelver}/build $_nv_llvm KBUILD_EXTMOD=${dkms_tree}/${PACKAGE_NAME}/${PACKAGE_VERSION}/build/uvm"
 CLEAN+="; make -C uvm clean"
