         *pPhysicalAddress = screen_info.lfb_base;
--- a/kernel/nv.c	2026-06-26 01:32:02.309835693 +0300
+++ b/kernel/nv.c	2026-06-26 01:30:22.131769529 +0300
@@ -1454,7 +1454,8 @@
